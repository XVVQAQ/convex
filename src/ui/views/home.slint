import { Theme } from "../theme.slint";
import { Comic } from "../types.slint";

import { ComicCard } from "../components/comic-card.slint";
import { Section } from "../components/section.slint";
import { Tag } from "../components/tag.slint";

component History {
    in property <[Comic]> reading-history;

    callback clicked();

    Section {
        title: "历史";

        width: 100%;
        clicked => {
            root.clicked();
        }

        HorizontalLayout {
            min-height: 160px;
            spacing: Theme.spacing-sm;

            for comic in reading-history: ComicCard {
                name: comic.title;
                cover: comic.cover;
                source: comic.source;
                comic-id: comic.comic-id;
            }
        }
    }
}

component Local {
    in property <[Comic]> local-comics;

    callback clicked();

    Section {
        title: "本地";

        width: 100%;
        clicked => {
            root.clicked();
        }

        HorizontalLayout {
            min-height: 160px;
            spacing: Theme.spacing-sm;

            for comic in local-comics: ComicCard {
                name: comic.title;
                cover: comic.cover;
                source: comic.source;
                comic-id: comic.comic-id;
            }
        }
    }
}

component Following {
    callback clicked();

    Section {
        title: "追更";

        width: 100%;
        clicked => {
            root.clicked();
        }

        Rectangle {
            min-height: 160px;
            width: 100%;
        }
    }
}

component Sources {
    in property <[string]> source-list;

    callback clicked();

    Section {
        title: "漫画源";

        width: 100%;
        clicked => {
            root.clicked();
        }

        HorizontalLayout {
            spacing: Theme.spacing-sm;

            for source in source-list: Tag {
                text: source;
            }
        }
    }
}

component ImageCollection {
    callback clicked();

    Section {
        title: "图片收藏";

        width: 100%;
        clicked => {
            root.clicked();
        }

        Rectangle {
            min-height: 160px;
            width: 100%;
        }
    }
}

export component HomePage inherits Rectangle {
    background: Theme.surface-sidebar;

    Flickable {
        width: 100%;
        height: 100%;

        VerticalLayout {
            padding: Theme.padding-md;
            spacing: 24px;

            History {
                clicked => {
                    // Navigate to history page
                }
            }

            Local {
                clicked => {
                    // Navigate to local page
                }
            }

            Following {
                clicked => {
                    // Navigate to following page
                }
            }

            Sources {
                clicked => {
                    // Navigate to sources page
                }
            }

            ImageCollection {
                clicked => {
                    // Navigate to image collection page
                }
            }
        }
    }
}
