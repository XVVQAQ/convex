export component HomePage inherits Rectangle {

    background: Theme.surface-sidebar;

    Flickable {
        width: 100%;
        height: 100%;

        VerticalLayout {
            padding: Theme.padding-md;
            spacing: Theme.spacing-xs;

            History { }

            Local { }

            Following { }

            Sources { }

            ImageCollection { }
        }
    }
