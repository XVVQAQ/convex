import { Theme } from "../theme.slint";

export component Tag {
    in property <string> text;
    private property <bool> selected;

    width: max(txt.preferred-width + 24px, 60px);
    height: 32px;

    Rectangle {
        width: 100%;
        height: 100%;
        border-radius: 16px;
        border-width: 1px;
        border-color: selected ? Theme.primary : Theme.divider;
        background: selected ? Theme.surface-active : transparent;

        animate background { duration: Theme.duration-fast; }

        txt := Text {
            text: root.text;
            font-size: Theme.font-size-sm;
            font-weight: selected ? Theme.font-weight-semibold : Theme.font-weight-normal;
            color: selected ? Theme.primary : Theme.text-primary;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    TouchArea {
        width: 100%;
        height: 100%;
        mouse-cursor: MouseCursor.pointer;
        clicked => {
            selected = !selected;
        }
    }
}
