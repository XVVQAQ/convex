import { NavBar } from "layout/navbar.slint";
import { Theme } from "theme.slint";

export component App inherits Window {
    width: 1024px;
    height: 768px;
    title: "Convex";

    in property <bool> reading;

    NavBar {
        width: 100%;
        height: 100%;
        window-width: root.width;
        reading: reading;
    }
}
