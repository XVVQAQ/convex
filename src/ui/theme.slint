export global Theme {
    // Palette
    in property <color> primary: #1a73e8;
    in property <color> on-primary: white;
    in property <color> text-primary: #202124;
    in property <color> text-secondary: #5f6368;
    in property <color> text-on-primary: white;
    in property <color> surface-sidebar: #fafafa;
    in property <color> surface-bottom-bar: #ffffff;
    in property <color> surface-hover: #f1f3f4;
    in property <color> surface-active: #e8f0fe;
    in property <color> surface-pressed: #d2e3fc;
    in property <color> divider: #e0e0e0;
    in property <color> shadow: rgba(0, 0, 0, 0.06);

    // Spacing
    in property <length> spacing-xs: 4px;
    in property <length> spacing-sm: 8px;
    in property <length> spacing-md: 12px;
    in property <length> spacing-lg: 16px;

    // Padding
    in property <length> padding-xs: 8px;
    in property <length> padding-sm: 12px;
    in property <length> padding-md: 16px;

    // Border Radius
    in property <length> radius-sm: 6px;
    in property <length> radius-md: 8px;
    in property <length> radius-lg: 12px;

    // Sizing
    in property <length> icon-box: 28px;
    in property <length> icon-size: 20px;
    in property <length> sidebar-expanded: 250px;
    in property <length> sidebar-collapsed: 64px;
    in property <length> menu-item-min-height: 44px;
    in property <length> bottom-bar-height: 64px;
    in property <length> brand-logo-size: 28px;
    in property <length> brand-area-min-height: 48px;

    // Typography
    in property <length> font-size-xs: 14px;
    in property <length> font-size-sm: 14px;
    in property <length> font-size-md: 16px;
    in property <length> font-size-lg: 18px;
    in property <int> font-weight-normal: 400;
    in property <int> font-weight-semibold: 600;
    in property <int> font-weight-bold: 700;

    // Animation
    in property <duration> duration-fast: 150ms;
    in property <duration> duration-normal: 200ms;

    // Breakpoints
    in property <length> bp-sidebar: 800px;
    in property <length> bp-mobile: 640px;

    // Shadow
    in property <length> shadow-blur: 8px;
}
