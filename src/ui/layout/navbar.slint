import { Theme } from "../theme.slint";

component MenuItem inherits Rectangle {
    in property <string> title;
    in property <image> icon;
    in property <bool> expanded;
    in property <bool> active;

    callback clicked();

    min-width: expanded ? 220px : Theme.sidebar-collapsed;
    min-height: Theme.menu-item-min-height;
    border-radius: Theme.radius-lg;
    background: item_area.has-hover ? Theme.surface-hover : transparent;
    animate background { duration: Theme.duration-fast; }

    states [
        active-active when active: {
            background: Theme.surface-active;
        }
        active-pressed when active && item_area.pressed: {
            background: Theme.surface-pressed;
        }
        pressed when !active && item_area.pressed: {
            background: Theme.surface-pressed;
        }
    ]

    item_area := TouchArea {
        width: 100%;
        height: 100%;
        mouse-cursor: MouseCursor.pointer;

        clicked => {
            root.clicked()
        }

        HorizontalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            padding-top: Theme.padding-xs;
            padding-bottom: Theme.padding-xs;
            spacing: Theme.spacing-md;
            alignment: start;

            Rectangle {
                width: Theme.icon-box;
                height: Theme.icon-box;
                border-radius: Theme.radius-sm;
                background: active ? Theme.primary : transparent;
                animate background { duration: Theme.duration-fast; }

                Image {
                    width: Theme.icon-size;
                    height: Theme.icon-size;
                    source: icon;
                    colorize: active ? Theme.on-primary : Theme.text-secondary;
                }
            }

            Text {
                visible: expanded;
                text: title;
                color: active ? Theme.primary : Theme.text-primary;
                font-size: Theme.font-size-sm;
                font-weight: active ? Theme.font-weight-semibold : Theme.font-weight-normal;
                vertical-alignment: center;
                horizontal-alignment: start;
                overflow: elide;
            }
        }
    }
}


component SideBar inherits Rectangle {
    in property <length> window-width;

    private property <length> collapsed-width: Theme.sidebar-collapsed;

    private property <bool> expanded: window-width >= Theme.bp-sidebar;

    width: expanded ? Theme.sidebar-expanded : collapsed-width;
    background: Theme.surface-sidebar;
    drop-shadow-offset-x: 2px;
    drop-shadow-offset-y: 0px;
    drop-shadow-blur: Theme.shadow-blur;
    drop-shadow-color: Theme.shadow;
    animate width {
        duration: Theme.duration-normal;
        easing: ease-out;
    }

    Rectangle {
        x: parent.width - 1px;
        width: 1px;
        height: 100%;
        background: Theme.divider;
    }

    VerticalLayout {
        padding-left: Theme.padding-xs;
        padding-right: Theme.padding-xs;
        padding-top: Theme.padding-md;
        padding-bottom: Theme.padding-md;
        spacing: Theme.spacing-xs;
        height: 100%;

        Rectangle {
            min-height: Theme.brand-area-min-height;

            HorizontalLayout {
                padding-left: Theme.spacing-md;
                padding-right: Theme.spacing-md;
                padding-top: Theme.padding-xs;
                padding-bottom: Theme.padding-xs;
                spacing: Theme.spacing-md;
                alignment: start;

                Rectangle {
                    width: Theme.brand-logo-size;
                    height: Theme.brand-logo-size;
                    border-radius: Theme.radius-sm;
                    background: Theme.primary;

                    Text {
                        text: "C";
                        color: Theme.on-primary;
                        font-size: Theme.font-size-md;
                        font-weight: Theme.font-weight-bold;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Text {
                    visible: expanded;
                    text: "Convex";
                    color: Theme.text-primary;
                    font-size: Theme.font-size-lg;
                    font-weight: Theme.font-weight-bold;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle {
            min-height: 1px;
            background: Theme.divider;
        }

        // MenuItemList

        VerticalLayout {
            height: 100%;
        }
    }
}

component BottonBar inherits Rectangle {
    height: Theme.bottom-bar-height;
    background: Theme.surface-bottom-bar;
    drop-shadow-offset-x: 0px;
    drop-shadow-offset-y: -2px;
    drop-shadow-blur: Theme.shadow-blur;
    drop-shadow-color: Theme.shadow;

    HorizontalLayout {
        padding-left: Theme.padding-md;
        padding-right: Theme.padding-md;
        padding-top: Theme.spacing-xs;
        padding-bottom: Theme.spacing-xs;
        alignment: space-around;
        height: 100%;

        // MenuItemList
    }
}

export component NavBar inherits Rectangle {
    in property <length> window-width;
    in property <bool> reading;

    private property <bool> is-mobile: window-width < Theme.bp-mobile;

    SideBar {
        visible: !is-mobile;
        window-width: window-width;
    }

    BottonBar {
        visible: is-mobile;
    }
}
